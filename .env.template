# ============================================================================
# Lend.Ai — Credenciales
# ============================================================================
# Copiá este archivo como .env y completá tus tokens.
# Las variables marcadas con # son opcionales y se pueden dejar vacías.

# GitHub (necesario para PRs, issues, búsqueda de código)
# GITHUB_TOKEN=

# Notion (necesario para integración con Notion)
# NOTION_TOKEN=

# PostgreSQL (para queries SQL)
# PG_HOST=localhost
# PG_PORT=5432
# PG_USER=postgres
# PG_PASSWORD=

# SMTP (para envío de emails)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=

# Slack (para integración con Slack)
# SLACK_USER_TOKEN=
# SLACK_BOT_TOKEN=

# Google Drive (para integración con Google Drive)
# GOOGLE_DRIVE_CLIENT_ID=
# GOOGLE_DRIVE_CLIENT_SECRET=
# GOOGLE_DRIVE_REFRESH_TOKEN=

# Modelos LLM
# DEFAULT_LLM_TIER=T3

# Directorio de instalación (se setea automáticamente)
# LEND_AI_HOME=${HOME}/.lend-ai
