  "mcp": {
    "engram": {
      "type": "local",
      "command": [
        "engram",
        "mcp",
        "--tools=agent"
      ]
    },
    "sequential-thinking": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "filesystem": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "{LEND_AI_HOME}"
      ]
    },
    "puppeteer": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-puppeteer"
      ]
    },
    "web-search": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "duckduckgo-mcp-server"
      ]
    },
    "github": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-github"
      ]
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "slack": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@jtalk22/slack-mcp"
      ]
    },
    "google-drive": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@piotr-agier/google-drive-mcp"
      ]
    },
    "notion": {
      "type": "local",
      "command": [
        "bash",
        "{LEND_AI_HOME}/mcp-servers/notion-wrapper.sh"
      ]
    },
    "smtp-email": {
      "type": "local",
      "command": [
        "bash",
        "{LEND_AI_HOME}/mcp-servers/smtp-wrapper.sh"
      ]
    },
    "postgres": {
      "type": "local",
      "command": [
