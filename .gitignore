# ============================================================================
# Lend.Ai — .gitignore
# ============================================================================

# Environment
.env
.env.local

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
*.egg-info/
dist/
build/
*.egg

# Jupyter
.ipynb_checkpoints/
*/.ipynb_checkpoints/*

# Data
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep
*.db
*.sqlite
*.sqlite3

# Node
node_modules/
npm-debug.log*

# IDE
.vscode/settings.json
.vscode/launch.json
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Config backups
*.backup.*
*.bak

# OpenCode
opencode.json.bak.*

# Ruff
.ruff_cache/

# Mypy
.mypy_cache/

# Coverage
htmlcov/
.coverage
.coverage.*
coverage.xml

# Backup directory
.backup-*/
